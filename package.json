{
  "name": "betterspend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "db:studio": "turbo db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "release:tag": "git tag -a v$npm_package_version -m \"Release v$npm_package_version\"",
    "release:push": "git push origin main --follow-tags"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
